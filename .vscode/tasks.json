{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Dev: Enable OpenGL Mode (native)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "cat > dev.cmake <<'EOF'\n# Auto-generated by VS Code task.\n# This file is git-ignored and only affects local development.\nset(EGE_BUILD_OPENGL ON CACHE BOOL \"Build with OpenGL backend\" FORCE)\nEOF\n"
            ],
            "options": {"cwd": "${workspaceFolder}"},
            "dependsOrder": "sequence",
            "dependsOn": [
                "Cleanup CMake Project",
                "Load CMake Project (Debug)",
                "Load CMake Project (Release)"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Dev: Disable OpenGL Mode (legacy wine)",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "rm -f dev.cmake\n"
            ],
            "options": {"cwd": "${workspaceFolder}"},
            "dependsOrder": "sequence",
            "dependsOn": [
                "Cleanup CMake Project",
                "Load CMake Project (Debug)",
                "Load CMake Project (Release)"
